# Пример файла secrets.yaml
# Скопируйте этот файл в secrets.yaml и заполните реальными значениями
# 
# ВАЖНО: secrets.yaml уже добавлен в .gitignore и не будет попадать в git

# WiFi настройки
wifi_ssid: "YOUR_WIFI_SSID"
wifi_password: "YOUR_WIFI_PASSWORD"

# MQTT брокер
mqtt_broker: "192.168.1.XXX"
mqtt_user: "YOUR_MQTT_USER"
mqtt_pass: "YOUR_MQTT_PASSWORD"

# OTA (Over-The-Air) обновления
# Сгенерируйте безопасный пароль: openssl rand -hex 16
ota_password: "YOUR_OTA_PASSWORD"

# API пароль для Home Assistant
# Сгенерируйте безопасный пароль: openssl rand -hex 16
api_password: "YOUR_API_PASSWORD"
